{
  "name": "reservasi-online",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "build": "npm --workspaces run build",
    "lint": "npm --workspaces run lint",
    "db:generate": "npm --workspace packages/db run generate",
    "db:migrate": "npm --workspace packages/db run migrate",
    "db:seed": "npm --workspace packages/db run seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  }
}
